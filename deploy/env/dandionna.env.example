JAVA_BIN=/usr/lib/jvm/java-21-openjdk-amd64/bin/java
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

DATABASE_URL=jdbc:postgresql://db-host:5432/dandi_db
DATABASE_ID=appuser
DATABASE_PW=change-me

REDIS_URL=redis-host
REDIS_PORT=6379
REDIS_PASSWORD=change-me

JWE_SECRET_B64=replace-with-base64-secret
FIREBASE_KEY_PATH=/etc/dandionna/firebase-service-account.json

MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_REGION=us-east-1
MINIO_ENDPOINT=http://minio.internal:9000
MINIO_BUCKET=dandi-bucket
MINIO_PUBLIC_ENDPOINT=https://minio.example.com

APP_CORS_ALLOWED_ORIGINS=https://owner.example.com,https://app.example.com
